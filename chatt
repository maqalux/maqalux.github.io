<!DOCTYPE html>
<html lang="az">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Maqalux - Modern Çat</title>
  <link rel="icon" href="logo.png" type="image/png">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

  <style>
    /* Şəkildəki dərin qradiyent effektli arxa fon */
    body { margin: 0; font-family: 'Poppins', sans-serif; background: linear-gradient(135deg, #090d22 0%, #082962 45%, #0151b1 100%); color: white; min-height: 100vh; display: flex; flex-direction: column; }
    
    header { display: flex; align-items: center; justify-content: space-between; height: 90px; padding: 0 30px; background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(15px); border-bottom: 1px solid rgba(255, 255, 255, 0.1); position: sticky; top: 0; z-index: 1000; }
    header a.logo img { height: 55px; transition: transform 0.4s ease; }
    header a.logo img:hover { transform: scale(1.1) rotate(-3deg); }
    
    nav ul { list-style: none; display: flex; gap: 10px; margin: 0; padding: 0; }
    nav ul li a { text-decoration: none; color: white; font-weight: 600; font-size: 16px; padding: 10px 22px; border-radius: 30px; transition: all 0.3s ease; }
    
    /* Şəkildəki qızılı-sarı "Onlayn çat" naviqasiya düyməsi */
    nav ul li a.active { background: linear-gradient(90deg, #ffc107, #ff9800); color: #0a1329; box-shadow: 0 4px 15px rgba(255,152,0,0.3); }

    main { flex: 1; display: flex; justify-content: center; align-items: center; padding: 20px; }
    
    /* Şəkildəki tünd şəffaf əsas çat konteyneri */
    .chat-container { width: 100%; max-width: 1000px; height: 650px; background: rgba(10, 22, 52, 0.5); backdrop-filter: blur(25px); border-radius: 24px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 20px 50px rgba(0,0,0,0.5); display: flex; flex-direction: column; overflow: hidden; }
    
    .chat-screen { display: none !important; height: 100%; width: 100%; }
    .chat-screen.active { display: flex !important; flex-direction: column; }

    /* Şəkildəki Giriş/Qeydiyyat Bölməsinin Dizaynı */
    #loginScreen { justify-content: center; align-items: center; position: relative; }
    
    .login-card { background: rgba(13, 27, 62, 0.75); backdrop-filter: blur(20px); padding: 50px 40px; border-radius: 24px; border: 1px solid rgba(255, 255, 255, 0.08); box-shadow: 0 25px 55px rgba(0, 0, 0, 0.6); width: 85%; max-width: 380px; display: flex; flex-direction: column; align-items: center; }
    
    /* Şəkildəki Qızılı-Sarı Başlıq mətni */
    .login-card h2 { font-size: 1.9em; color: #ffaa00; margin: 0 0 12px 0; font-weight: 700; text-align: center; width: 100%; letter-spacing: 0.5px; }
    .login-card p { color: rgba(255, 255, 255, 0.6); font-size: 14px; margin: 0 0 30px 0; text-align: center; }
    
    .input-group { display: flex; flex-direction: column; gap: 16px; width: 100%; }
    
    /* Şəkildəki kimi tamamilə oval (pill-shaped) inputlar */
    .custom-input { padding: 15px 25px; border-radius: 30px; border: 1px solid rgba(255,255,255,0.15); background: rgba(255,255,255,0.08); color: white; font-size: 15px; outline: none; text-align: left; transition: all 0.3s ease; width: 100%; box-sizing: border-box; }
    .custom-input:focus { border-color: #ffa200; background: rgba(255,255,255,0.15); box-shadow: 0 0 12px rgba(255,162,0,0.3); }
    .custom-input::placeholder { color: rgba(255,255,255,0.4); }
    
    /* Şifrə Gözünün Oval İnputa Uyğunlaşdırılması */
    .password-wrapper { position: relative; width: 100%; display: flex; align-items: center; }
    .password-wrapper .custom-input { padding-right: 55px; }
    .toggle-password { position: absolute; right: 22px; cursor: pointer; font-size: 18px; user-select: none; color: rgba(255, 255, 255, 0.5); transition: 0.2s; z-index: 5; }
    .toggle-password:hover { color: white; transform: scale(1.1); }

    /* Şəkildəki Qızılı-Sarı Giriş düyməsi */
    .login-btn { background: linear-gradient(90deg, #ffc107, #ff9800); color: #06163a; border: none; padding: 16px; border-radius: 30px; font-weight: 700; font-size: 15px; cursor: pointer; transition: 0.3s; margin-top: 5px; width: 100%; box-shadow: 0 4px 15px rgba(255,152,0,0.2); }
    .login-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 25px rgba(255,152,0,0.4); }

    .switch-text { color: rgba(255,255,255,0.5); font-size: 13.5px; margin-top: 20px; text-align: center; width: 100%; }
    .switch-text span { color: #ffb700; cursor: pointer; font-weight: 600; text-decoration: underline; margin-left: 5px; }
    .switch-text span:hover { color: white; }

    /* Çatın Daxili Hissəsi */
    .chat-header { background: rgba(5, 12, 31, 0.5); padding: 18px 25px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .chat-header h3 { margin: 0; color: white; }
    .logout-btn { background: rgba(220, 53, 69, 0.8); color: white; border: none; padding: 8px 18px; border-radius: 20px; cursor: pointer; font-weight: 600; transition: 0.3s; }
    .logout-btn:hover { background: #dc3545; }

    .chat-body { flex: 1; display: flex; overflow: hidden; }
    .messages-area { flex: 1; padding: 20px; overflow-y: auto; display: flex; flex-direction: column; gap: 15px; background: rgba(0, 0, 0, 0.15); }
    .messages-area::-webkit-scrollbar { width: 6px; }
    .messages-area::-webkit-scrollbar-thumb { background: rgba(255,162,0,0.3); border-radius: 10px; }
    
    .sidebar-users { width: 220px; background: rgba(5, 12, 31, 0.3); border-left: 1px solid rgba(255,255,255,0.08); padding: 0; overflow: hidden; display: flex; flex-direction: column; }
    .sidebar-users h4 { margin: 0; color: #ffaa00; border-bottom: 1px solid rgba(255,162,0,0.2); padding: 20px 20px 12px 20px; flex-shrink: 0; background: rgba(5, 12, 31, 0.55); backdrop-filter: blur(10px); position: sticky; top: 0; z-index: 2; }
    #activeUsersList { flex: 1; overflow-y: auto; padding: 14px 20px 20px 20px; display: flex; flex-direction: column; gap: 10px; }
    #activeUsersList::-webkit-scrollbar { width: 5px; }
    #activeUsersList::-webkit-scrollbar-thumb { background: rgba(255,162,0,0.3); border-radius: 10px; }

    .user-badge { background: rgba(255,255,255,0.06); padding: 8px 14px; border-radius: 20px; font-size: 14px; display: flex; align-items: center; gap: 8px; cursor: pointer; transition: 0.25s; position: relative; }
    .user-badge:hover { background: rgba(255,255,255,0.13); transform: translateX(-2px); }
    .user-badge.role-admin { border: 1px solid rgba(255, 80, 80, 0.4); }
    .user-badge.role-moderator { border: 1px solid rgba(120, 170, 255, 0.4); }
    .user-badge.user-banned { opacity: 0.5; border: 1px solid rgba(255, 60, 60, 0.3); }
    .user-badge .role-tag { font-size: 10px; opacity: 0.7; margin-left: auto; }

    /* Avatar konteyneri + onlayn olduğunu göstərən yaşıl işıq */
    .sidebar-avatar-wrap { position: relative; width: 22px; height: 22px; flex-shrink: 0; }
    .sidebar-avatar { width: 22px; height: 22px; border-radius: 50%; object-fit: cover; display: block; }
    .online-dot { position: absolute; bottom: -1px; right: -1px; width: 8px; height: 8px; border-radius: 50%; background: #555; border: 2px solid rgba(13, 27, 62, 1); }
    .online-dot.is-online { background: #2ecc71; box-shadow: 0 0 6px rgba(46, 204, 113, 0.8); }

    .msg-bubble { max-width: 75%; padding: 13px 18px; border-radius: 20px; font-size: 15px; position: relative; word-wrap: break-word; display: flex; flex-direction: column; }
    .msg-bubble b { font-size: 0.85em; opacity: 0.9; color: #ffc107; }
    .msg-bubble img { max-width: 100%; max-height: 200px; border-radius: 12px; margin-top: 7px; object-fit: cover; }
    
    .msg-me { background: linear-gradient(135deg, #024397, #00285e); color: white; align-self: flex-end; border-bottom-right-radius: 5px; box-shadow: 0 4px 15px rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.05); }
    .msg-other { background: rgba(255, 255, 255, 0.08); color: white; align-self: flex-start; border-bottom-left-radius: 5px; border: 1px solid rgba(255,255,255,0.05); }
    
    .delete-btn { background: none; border: none; color: rgba(255,255,255,0.5); cursor: pointer; font-size: 12px; align-self: flex-end; margin-top: 5px; padding: 0; }
    .delete-btn:hover { color: #ff4d4d; text-decoration: underline; }

    /* ====================== MESAJ SAATI + WHATSAPP TİPLİ TİCK STATUSU ====================== */
    .msg-meta { display: flex; align-items: center; gap: 4px; align-self: flex-end; margin-top: 4px; font-size: 11px; color: rgba(255,255,255,0.55); user-select: none; }
    .msg-other .msg-meta { align-self: flex-start; }
    .msg-ticks { display: inline-flex; align-items: center; line-height: 0; }
    .msg-ticks svg { width: 15px; height: 11px; display: block; }
    .msg-ticks .tick-path { fill: none; stroke: rgba(255,255,255,0.55); stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
    .msg-ticks.ticks-read .tick-path { stroke: #2ecc71; }

    /* ====================== REPLY / FORWARD / REAKSİYA ====================== */
    .msg-bubble { cursor: pointer; }
    .msg-reply-preview { background: rgba(0,0,0,0.22); border-left: 3px solid #ffaa00; border-radius: 8px; padding: 6px 10px; margin-bottom: 6px; font-size: 12.5px; opacity: 0.85; max-width: 100%; }
    .msg-reply-preview b { color: #ffc107; display: block; font-size: 0.9em; margin-bottom: 1px; }
    .msg-reply-preview .reply-text { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block; }
    .msg-forward-tag { font-size: 11px; opacity: 0.6; font-style: italic; margin-bottom: 4px; display: flex; align-items: center; gap: 4px; }

    .msg-reactions-bar { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 6px; }
    .reaction-chip { background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); border-radius: 12px; padding: 1px 7px; font-size: 12px; display: flex; align-items: center; gap: 3px; cursor: pointer; transition: 0.2s; }
    .reaction-chip:hover { background: rgba(255,255,255,0.15); }
    .reaction-chip.mine { border-color: #ffaa00; background: rgba(255,170,0,0.18); }

    /* Mesaj üzərinə uzun-basma/sağ-klik konteks menyusu */
    .msg-context-menu { position: fixed; z-index: 6000; background: rgba(13, 27, 62, 0.97); backdrop-filter: blur(18px); border: 1px solid rgba(255,255,255,0.12); border-radius: 16px; box-shadow: 0 20px 50px rgba(0,0,0,0.55); padding: 8px; display: flex; flex-direction: column; min-width: 190px; gap: 2px; }
    .msg-context-menu .ctx-emojis { display: flex; gap: 4px; padding: 6px 6px 10px 6px; border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 4px; }
    .msg-context-menu .ctx-emojis span { font-size: 20px; cursor: pointer; transition: 0.2s; border-radius: 50%; padding: 2px; }
    .msg-context-menu .ctx-emojis span:hover { transform: scale(1.25); background: rgba(255,255,255,0.08); }
    .ctx-item { display: flex; align-items: center; gap: 10px; padding: 9px 12px; border-radius: 10px; cursor: pointer; font-size: 13.5px; color: white; transition: 0.15s; background: none; border: none; text-align: left; width: 100%; box-sizing: border-box; }
    .ctx-item:hover { background: rgba(255,255,255,0.1); }
    .ctx-item.danger { color: #ff6b6b; }
    .ctx-overlay { position: fixed; inset: 0; z-index: 5999; }

    /* ====================== STİKER / GIF SEÇİCİSİ ====================== */
    .sticker-panel { position: absolute; bottom: 70px; right: 20px; width: 320px; max-height: 380px; background: rgba(10, 22, 52, 0.97); backdrop-filter: blur(25px); border: 1px solid rgba(255,255,255,0.12); border-radius: 18px; box-shadow: 0 20px 50px rgba(0,0,0,0.55); display: none; flex-direction: column; overflow: hidden; z-index: 2500; }
    .sticker-panel.active { display: flex; }
    .sticker-tabs { display: flex; border-bottom: 1px solid rgba(255,255,255,0.1); flex-shrink: 0; }
    .sticker-tab { flex: 1; text-align: center; padding: 12px 8px; cursor: pointer; font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.5); border-bottom: 2px solid transparent; transition: 0.2s; }
    .sticker-tab.active { color: #ffaa00; border-bottom-color: #ffaa00; }
    .sticker-body { flex: 1; overflow-y: auto; padding: 12px; }
    .sticker-body::-webkit-scrollbar { width: 5px; }
    .sticker-body::-webkit-scrollbar-thumb { background: rgba(255,162,0,0.3); border-radius: 10px; }
    .sticker-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
    .sticker-grid img, .sticker-grid .emoji-sticker { width: 100%; aspect-ratio: 1/1; object-fit: contain; cursor: pointer; border-radius: 10px; transition: 0.2s; background: rgba(255,255,255,0.04); }
    .sticker-grid img:hover, .sticker-grid .emoji-sticker:hover { transform: scale(1.12); background: rgba(255,255,255,0.1); }
    .emoji-sticker { display: flex; align-items: center; justify-content: center; font-size: 30px; }
    .sticker-empty-state { text-align: center; color: rgba(255,255,255,0.4); font-size: 13px; padding: 40px 10px; line-height: 1.6; }

    /* ====================== AVATAR AÇILAN MENYUSU ====================== */
    .avatar-dropdown { position: absolute; top: 65px; left: 25px; width: 230px; background: rgba(13, 27, 62, 0.97); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.12); border-radius: 16px; box-shadow: 0 20px 50px rgba(0,0,0,0.55); padding: 8px; display: none; flex-direction: column; gap: 2px; z-index: 2600; }
    .avatar-dropdown.active { display: flex; }
    .avatar-dropdown .ctx-item { font-size: 14px; padding: 10px 12px; }

    /* ====================== PROFİL AYARLARI MODALI ====================== */
    .settings-section { width: 100%; text-align: left; }
    .settings-section h4 { color: #ffaa00; font-size: 14px; margin: 0 0 12px 0; }
    .settings-divider { width: 100%; height: 1px; background: rgba(255,255,255,0.1); margin: 20px 0; }

    /* ====================== AKTİV İSTİFADƏÇİ BADGE-İNDƏ İDARƏETMƏ İKONLARI ====================== */
    .user-badge { flex-wrap: wrap; }
    .badge-actions { display: flex; align-items: center; gap: 5px; margin-left: 6px; }
    .badge-action-icon { font-size: 12px; opacity: 0.65; cursor: pointer; transition: 0.2s; padding: 2px; border-radius: 50%; line-height: 1; }
    .badge-action-icon:hover { opacity: 1; transform: scale(1.2); }

    /* ====================== MESAJ INPUT: TEXTAREA (AVTO-GENİŞLƏNƏN) ====================== */
    .message-input { resize: none; overflow-y: auto; font-family: 'Poppins', sans-serif; line-height: 1.4; max-height: 110px; }

    .input-bar { padding: 15px 20px; background: rgba(5, 12, 31, 0.5); border-top: 1px solid rgba(255,255,255,0.1); display: flex; gap: 12px; align-items: center; }
    .message-input { padding: 12px 22px; border-radius: 22px; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.06); color: white; font-size: 15px; outline: none; }
    .message-input::placeholder { color: rgba(255,255,255,0.4); }
    .message-input:focus { border-color: #ff9800; }

    /* ====================== WHATSAPP TİPLİ VAHİD INPUT PİLL-İ (😊 mətn 🖼️) ====================== */
    .input-pill { flex: 1; display: flex; align-items: flex-end; gap: 6px; padding: 6px 10px; border-radius: 24px; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.06); transition: border-color 0.2s; }
    .input-pill:focus-within { border-color: #ff9800; }
    .input-pill .message-input { flex: 1; padding: 6px 4px; border: none; background: transparent; border-radius: 0; }
    .input-pill .pill-icon-btn { flex-shrink: 0; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 19px; background: none; transition: 0.2s; margin-bottom: 1px; }
    .input-pill .pill-icon-btn:hover { background: rgba(255,255,255,0.1); }
    
    .media-label { background: rgba(255,255,255,0.1); width: 45px; height: 45px; border-radius: 50%; display: flex; justify-content: center; align-items: center; cursor: pointer; font-size: 20px; transition: 0.3s; }
    .media-label:hover { background: rgba(255,255,255,0.2); transform: scale(1.05); }
    
    .send-btn { background: linear-gradient(90deg, #ffc107, #ff9800); color: #06163a; border: none; width: 45px; height: 45px; border-radius: 50%; cursor: pointer; display: flex; justify-content: center; align-items: center; font-size: 20px; transition: 0.3s; box-shadow: 0 4px 12px rgba(255,152,0,0.2); flex-shrink: 0; }
    .send-btn:hover { transform: scale(1.1); box-shadow: 0 4px 18px rgba(255,152,0,0.4); }

    footer { text-align: center; padding: 20px; color: #ffaa00; font-weight: 600; font-size: 14px; border-top: 1px solid rgba(255,255,255,0.05); background: rgba(0, 0, 0, 0.2); }
    
    /* Profil Şəklinin Konteyneri */
    .avatar-container { position: relative; width: 45px; height: 45px; border-radius: 50%; overflow: hidden; cursor: pointer; border: 2px solid #ffaa00; flex-shrink: 0; }
    .avatar-container img { width: 100%; height: 100%; object-fit: cover; }

    /* Üzərinə gələndə şəffaf "Dəyiş" effekti */
    .avatar-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); display: flex; justify-content: center; align-items: center; opacity: 0; transition: 0.3s; font-size: 16px; }
    .avatar-container:hover .avatar-overlay { opacity: 1; }

    /* Mesajlar daxilindəki kiçik profil şəkilləri */
    .msg-avatar { width: 32px; height: 32px; border-radius: 50%; object-fit: cover; border: 1px solid rgba(255,170,0,0.4); flex-shrink: 0; }
    .msg-header { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
    
    /* Aktiv istifadəçi paneli şəkli */
    .sidebar-avatar { width: 22px; height: 22px; border-radius: 50%; object-fit: cover; }
   
    /* ====================== TOAST BİLDİRİŞ SİSTEMİ ====================== */
    #toastContainer { position: fixed; top: 100px; right: 25px; z-index: 5000; display: flex; flex-direction: column; gap: 12px; max-width: 340px; }
    .toast { background: rgba(13, 27, 62, 0.92); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.12); border-left: 4px solid #ffaa00; border-radius: 14px; padding: 14px 18px; box-shadow: 0 15px 35px rgba(0,0,0,0.5); color: white; font-size: 14px; line-height: 1.4; opacity: 0; transform: translateX(40px); transition: all 0.35s ease; }
    .toast.show { opacity: 1; transform: translateX(0); }
    .toast.toast-success { border-left-color: #2ecc71; }
    .toast.toast-error { border-left-color: #e74c3c; }
    .toast.toast-info { border-left-color: #ffaa00; }

    /* ====================== GOOGLE GİRİŞ DÜYMƏSİ ====================== */
    .google-btn { display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; background: rgba(255,255,255,0.95); color: #1f1f1f; border: 1px solid rgba(255,255,255,0.2); padding: 14px; border-radius: 30px; font-weight: 600; font-size: 14.5px; cursor: pointer; transition: 0.3s; margin-top: 14px; }
    .google-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(255,255,255,0.2); }
    .google-btn img { width: 19px; height: 19px; }

    .divider-row { display: flex; align-items: center; gap: 12px; width: 100%; margin: 18px 0 0 0; }
    .divider-row .line { flex: 1; height: 1px; background: rgba(255,255,255,0.15); }
    .divider-row span { color: rgba(255,255,255,0.4); font-size: 12.5px; }

    .forgot-pass-link { color: rgba(255,255,255,0.5); font-size: 13px; cursor: pointer; text-align: center; width: 100%; margin-top: 14px; text-decoration: underline; transition: 0.2s; }
    .forgot-pass-link:hover { color: #ffb700; }

    /* ====================== ŞİFRƏNİ UNUTDUM MODALI ====================== */
    .modal-overlay { position: fixed; inset: 0; background: rgba(3, 7, 20, 0.75); backdrop-filter: blur(6px); z-index: 4000; display: none; justify-content: c