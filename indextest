    // KÖMƏKÇİ FONKSİYALAR
    // ============================================================
    function showToast(message, type = 'info', duration = 4000) {
      const container = document.getElementById('toastContainer');
      const toast = document.createElement('div');
      toast.className = `toast toast-${type}`;
      toast.innerText = message;
      container.appendChild(toast);
      requestAnimationFrame(() => toast.classList.add('show'));
      setTimeout(() => {
        toast.classList.remove('show');
        setTimeout(() => toast.remove(), 400);
      }, duration);
    }

    function togglePasswordVisibility(inputId, iconEl) {
      const inp = document.getElementById(inputId);
      if (!inp) return;
      if (inp.type === 'password') {
        inp.type = 'text';
        iconEl.innerText = '🙈';
      } else {
        inp.type = 'password';
        iconEl.innerText = '👁️';
      }
    }

    function toggleAuthForms(mode) {
      document.getElementById('loginFormCard').style.display = mode === 'register' ? 'none' : 'flex';
      document.getElementById('registerFormCard').style.display = mode === 'register' ? 'flex' : 'none';
    }

    function toggleDropdown(e) {
      e.stopPropagation();
      const menu = document.getElementById('dropdownMenu');
      menu.classList.toggle('active');
    }

    document.addEventListener('click', function (e) {
      const menu = document.getElementById('dropdownMenu');
      if (menu && menu.classList.contains('active') && !e.target.closest('.header-right')) {
        menu.classList.remove('active');
      }
    });

    // ============================================================
    // AUTH STATE
    // ============================================================
    auth.onAuthStateChanged(async (user) => {
      if (user) {
        try {
          const snap = await db.ref(`users/${user.uid}`).once('value');
          if (snap.exists()) {
            currentUserData = snap.val();
            currentUserData.uid = user.uid;

            if (currentUserData.isBanned) {
              showToast('Hesabınız qara siyahıya alınıb.', 'error', 5000);
              await auth.signOut();
              location.reload();
              return;
            }

            // Online status
            await db.ref(`users/${user.uid}/online`).set(true);
            db.ref(`users/${user.uid}/online`).onDisconnect().set(false);

            // UI yenilə
            document.getElementById('headerAvatar').src = currentUserData.avatarUrl || 'https://www.w3schools.com/howto/img_avatar.png';
            document.getElementById('authSection').style.display = 'none';
            document.getElementById('mainContent').style.display = 'block';

            showToast(`Xoş gəldiniz, ${currentUserData.nick}!`, 'success');
          } else {
            await auth.signOut();
          }
        } catch (err) {
          showToast('Xəta: ' + err.message, 'error');
        }
      } else {
        currentUserData = null;
        document.getElementById('authSection').style.display = 'flex';
        document.getElementById('mainContent').style.display = 'none';
        document.getElementById('headerAvatar').src = 'https://www.w3schools.com/howto/img_avatar.png';
      }
    });

    // ============================================================
    // LOGIN / REGISTER / GOOGLE
    // ============================================================
    window.handleLogin = async function () {
      const email = document.getElementById('loginEmailInput').value.trim();
      const pass = document.getElementById('loginPasswordInput').value.trim();
      if (!email || !pass) return showToast('Email və şifrəni daxil edin.', 'error');
      try {
        await auth.signInWithEmailAndPassword(email, pass);
      } catch (err) {
        showToast('Xəta: ' + err.message, 'error');
      }
    };

    window.handleRegister = async function () {
      const nick = document.getElementById('registerNicknameInput').value.trim();
      const email = document.getElementById('registerEmailInput').value.trim();
      const pass = document.getElementById('registerPasswordInput').value.trim();
      if (!nick || !email || !pass) return showToast('Bütün xanaları doldurun.', 'error');
      try {
        const cred = await auth.createUserWithEmailAndPassword(email, pass);
        await db.ref(`users/${cred.user.uid}`).set({
          nick: nick,
          email: email,
          role: 'user',
          avatarUrl: 'https://www.w3schools.com/howto/img_avatar.png',
          online: true,
          isBanned: false
        });
        showToast('Qeydiyyat uğurludur!', 'success');
      } catch (err) {
        showToast('Xəta: ' + err.message, 'error');
      }
    };

    window.handleGoogleLogin = async function () {
      const provider = new firebase.auth.GoogleAuthProvider();
      try {
        const result = await auth.signInWithPopup(provider);
        const user = result.user;
        const snap = await db.ref(`users/${user.uid}`).once('value');
        if (!snap.exists()) {
          await db.ref(`users/${user.uid}`).set({
            nick: user.displayName || 'Google İstifadəçisi',
            email: user.email,
            role: 'user',
            avatarUrl: user.photoURL || 'https://www.w3schools.com/howto/img_avatar.png',
            online: true,
            isBanned: false
          });
        } else {
          await db.ref(`users/${user.uid}/online`).set(true);
        }
        showToast('Google ilə daxil oldunuz!', 'success');
      } catch (err) {
        showToast('Google Xətası: ' + err.message, 'error');
      }
    };

    window.handleLogout = async function () {
      if (auth.currentUser) {
        await db.ref(`users/${auth.currentUser.uid}/online`).set(false);
        await auth.signOut();
        showToast('Çıxış etdiniz.', 'info');
        document.getElementById('dropdownMenu').classList.remove('active');
      }
    };

    // ============================================================
    // ŞİFRƏNİ UNUTDUM
    // ============================================================
    window.openForgotPasswordModal = function () {
      document.getElementById('forgotEmailInput').value = '';
      document.getElementById('forgotPasswordModal').classList.add('active');
    };
    window.closeForgotPasswordModal = function () {
      document.getElementById('forgotPasswordModal').classList.remove('active');
    };
    window.submitForgotPassword = function () {
      const email = document.getElementById('forgotEmailInput').value.trim();
      if (!email) return showToast('E-poçt ünvanınızı daxil edin.', 'error');
      auth.sendPasswordResetEmail(email).then(() => {
        showToast('Bərpa linki e-poçtunuza göndərildi.', 'success');
        closeForgotPasswordModal();
      }).catch(err => {
        showToast('Xəta: ' + err.message, 'error');
      });
    };

    // ============================================================
    // ŞİFRƏ DƏYİŞDİRMƏ
    // ============================================================
    window.openChangePasswordModal = function () {
      document.getElementById('oldPassInput').value = '';
      document.getElementById('newPassInput').value = '';
      document.getElementById('changePasswordModal').classList.add('active');
      document.getElementById('dropdownMenu').classList.remove('active');
    };
    window.closeChangePasswordModal = function () {
      document.getElementById('changePasswordModal').classList.remove('active');
    };
    window.submitChangePassword = function () {
      const oldPass = document.getElementById('oldPassInput').value.trim();
      const newPass = document.getElementById('newPassInput').value.trim();
      if (!oldPass || !newPass) return showToast('Hər iki xananı doldurun.', 'error');
      const user = auth.currentUser;
      if (!user) return showToast('Daxil olmamısınız.', 'error');
      const cred = firebase.auth.EmailAuthProvider.credential(user.email, oldPass);
      user.reauthenticateWithCredential(cred).then(() => {
        return user.updatePassword(newPass);
      }).then(() => {
        showToast('Şifrə uğurla yeniləndi!', 'success');
        closeChangePasswordModal();
      }).catch(err => {
        showToast('Xəta: ' + err.message, 'error');
      });
    };

    // ============================================================
    // PROFİL ŞƏKLİNİ DƏYİŞ (imgbb ilə)
    // ============================================================
    window.changeProfilePicture = function () {
      document.getElementById('dropdownMenu').classList.remove('active');
      const input = document.createElement('input');
      input.type = 'file';
      input.accept = 'image/*';
      input.onchange = async function (e) {
        const file = e.target.files[0];
        if (!file) return;
        const formData = new FormData();
        formData.append('image', file);
        try {
          const res = await fetch('https://api.imgbb.com/1/upload?key=f1900369f20ec530cb390fc20be7cf8a', {
            method: 'POST',
            body: formData
          });
          const data = await res.json();
          if (data.success) {
            const url = data.data.url;
            document.getElementById('headerAvatar').src = url;
            if (auth.currentUser) {
              await db.ref(`users/${auth.currentUser.uid}/avatarUrl`).set(url);
            }
            showToast('Profil şəkli yeniləndi!', 'success');
          } else {
            showToast('Şəkil yüklənə bilmədi.', 'error');
          }
        } catch (err) {
          showToast('Xəta: ' + err.message, 'error');
        }
      };
      input.click();
    };

    // ============================================================
    // HESABI SİL
    // ============================================================
    window.deleteAccount = function () {
      document.getElementById('dropdownMenu').classList.remove('active');
      document.getElementById('deletePassInput').value = '';
      document.getElementById('deleteAccountModal').classList.add('active');
    };
    window.closeDeleteAccountModal = function () {
      document.getElementById('deleteAccountModal').classList.remove('active');
    };
    window.submitDeleteAccount = function () {
      const pass = document.getElementById('deletePassInput').value.trim();
      if (!pass) return showToast('Şifrənizi daxil edin.', 'error');
      if (!confirm('Hesabınızı həmişəlik silmək istədiyinizdən tam əminsiniz? Bu əməliyyat geri qaytarıla bilməz.')) return;
      const user = auth.currentUser;
      if (!user) return showToast('Daxil olmamısınız.', 'error');
      const cred = firebase.auth.EmailAuthProvider.credential(user.email, pass);
      user.reauthenticateWithCredential(cred).then(() => {
        return db.ref(`users/${user.uid}`).remove();
      }).then(() => {
        return user.delete();
      }).then(() => {
        showToast('Hesabınız silindi.', 'success');
        location.reload();
      }).catch(err => {
        showToast('Xəta: ' + err.message, 'error');
      });
    };

