<!DOCTYPE html>
<html lang="az">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Maqalux</title>
  <link rel="icon" href="logo.png" type="image/png">
  <meta name="description" content="Xoş Gəldiniz – Faydalı məlumatlar, əyləncəli məzmun və gündəlik həyat üçün tövsiyələr.">
  <meta property="og:title" content="Xoş Gəldiniz – Faydalı və Əyləncəli" />
  <meta property="og:description" content="Faydalı məlumatlar, əyləncəli məzmun və gündəlik həyat üçün tövsiyələr." />
  <meta property="og:image" content="logo.png" />
  <meta property="og:type" content="website" />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

  <style>
    /* === Ümumi tərz === */
    body {
      margin: 0;
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(135deg, #1e002f, #0055a5);
      color: white;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* === Header === */
    header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(15px);
      padding: 15px 30px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.2);
      position: sticky;
      top: 0;
      z-index: 1000;
      box-shadow: 0 5px 30px rgba(0,0,0,0.3);
      height: 90px;
      box-sizing: border-box;
    }

    header a.logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      height: 100%;
    }

    header a.logo img {
      height: 55px;
      width: auto;
      object-fit: contain;
      transition: transform 0.4s ease;
      display: block;
      margin: auto 0;
    }

    header a.logo img:hover {
      transform: scale(1.1) rotate(-3deg);
    }

    nav ul {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 10px;
      margin: 0;
      padding: 0;
    }

    nav ul li a {
      text-decoration: none;
      color: white;
      font-weight: 600;
      padding: 10px 18px;
      border-radius: 30px;
      position: relative;
      overflow: hidden;
      transition: all 0.3s ease;
      font-size: 16px;
      line-height: 1;
    }

    nav ul li a::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 0%;
      height: 100%;
      background: linear-gradient(90deg, #FFD700, #FF8C00);
      transition: width 0.4s ease;
      z-index: -1;
      border-radius: 30px;
    }

    nav ul li a:hover::before { width: 100%; }
    nav ul li a:hover { color: black; transform: translateY(-2px); }
    nav ul li a.active {
      background: linear-gradient(90deg, #FFD700, #FF8C00);
      color: black;
      box-shadow: 0 0 20px rgba(255,215,0,0.6);
    }

    /* Sağ tərəfdə profil şəkli */
    .header-right {
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .profile-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid #ffaa00;
      cursor: pointer;
      transition: 0.2s;
    }

    .profile-avatar:hover {
      transform: scale(1.1);
    }

    .dropdown-menu {
      position: absolute;
      top: 70px;
      right: 20px;
      background: rgba(13, 27, 62, 0.95);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 16px;
      box-shadow: 0 20px 50px rgba(0,0,0,0.55);
      padding: 8px;
      display: none;
      flex-direction: column;
      min-width: 200px;
      z-index: 2000;
    }

    .dropdown-menu.active {
      display: flex;
    }

    .dropdown-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      border-radius: 10px;
      cursor: pointer;
      font-size: 14px;
      color: white;
      transition: 0.15s;
      background: none;
      border: none;
      text-align: left;
      width: 100%;
      box-sizing: border-box;
      font-family: 'Poppins', sans-serif;
    }

    .dropdown-item:hover {
      background: rgba(255,255,255,0.1);
    }

    .dropdown-item.danger {
      color: #ff6b6b;
    }

    /* === Əsas bölmə === */
    main {
      flex: 1;
      max-width: 900px;
      margin: 60px auto;
      padding: 0 20px;
      width: 100%;
      box-sizing: border-box;
    }

    .content-wrapper {
      background: rgba(255,255,255,0.1);
      backdrop-filter: blur(20px);
      padding: 40px;
      border-radius: 20px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.3);
      animation: fadeIn 1s ease;
      text-align: center;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .content-wrapper h1 {
      font-size: 2.4em;
      background: linear-gradient(90deg, #FFD700, #FFA500);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 20px;
    }

    .content-wrapper p {
      font-size: 1.1em;
      line-height: 1.8;
      color: #f8f8f8;
    }

    /* === Auth formaları === */
    .auth-overlay {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 70vh;
      padding: 20px;
    }

    .auth-card {
      background: rgba(13, 27, 62, 0.85);
      backdrop-filter: blur(20px);
      padding: 40px 35px;
      border-radius: 24px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 25px 55px rgba(0, 0, 0, 0.6);
      width: 100%;
      max-width: 380px;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .auth-card h2 {
      font-size: 1.9em;
      color: #ffaa00;
      margin: 0 0 12px 0;
      font-weight: 700;
      text-align: center;
      width: 100%;
      letter-spacing: 0.5px;
    }

    .auth-card p.sub {
      color: rgba(255, 255, 255, 0.6);
      font-size: 14px;
      margin: 0 0 30px 0;
      text-align: center;
    }

    .input-group {
      display: flex;
      flex-direction: column;
      gap: 16px;
      width: 100%;
    }

    .custom-input {
      padding: 15px 25px;
      border-radius: 30px;
      border: 1px solid rgba(255,255,255,0.15);
      background: rgba(255,255,255,0.08);
      color: white;
      font-size: 15px;
      outline: none;
      text-align: left;
      transition: all 0.3s ease;
      width: 100%;
      box-sizing: border-box;
    }

    .custom-input:focus {
      border-color: #ffa200;
      background: rgba(255,255,255,0.15);
      box-shadow: 0 0 12px rgba(255,162,0,0.3);
    }

    .custom-input::placeholder {
      color: rgba(255,255,255,0.4);
    }

    .password-wrapper {
      position: relative;
      width: 100%;
      display: flex;
      align-items: center;
    }

    .password-wrapper .custom-input {
      padding-right: 55px;
    }

    .toggle-password {
      position: absolute;
      right: 22px;
      cursor: pointer;
      font-size: 18px;
      user-select: none;
      color: rgba(255, 255, 255, 0.5);
      transition: 0.2s;
      z-index: 5;
    }

    .toggle-password:hover {
      color: white;
      transform: scale(1.1);
    }

    .login-btn {
      background: linear-gradient(90deg, #ffc107, #ff9800);
      color: #06163a;
      border: none;
      padding: 16px;
      border-radius: 30px;
      font-weight: 700;
      font-size: 15px;
      cursor: pointer;
      transition: 0.3s;
      margin-top: 5px;
      width: 100%;
      box-shadow: 0 4px 15px rgba(255,152,0,0.2);
    }

    .login-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 25px rgba(255,152,0,0.4);
    }

    .switch-text {
      color: rgba(255,255,255,0.5);
      font-size: 13.5px;
      margin-top: 20px;
      text-align: center;
      width: 100%;
    }

    .switch-text span {
      color: #ffb700;
      cursor: pointer;
      font-weight: 600;
      text-decoration: underline;
      margin-left: 5px;
    }

    .switch-text span:hover {
      color: white;
    }

    .forgot-pass-link {
      color: rgba(255,255,255,0.5);
      font-size: 13px;
      cursor: pointer;
      text-align: center;
      width: 100%;
      margin-top: 14px;
      text-decoration: underline;
      transition: 0.2s;
    }

    .forgot-pass-link:hover {
      color: #ffb700;
    }

    .google-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      background: rgba(255,255,255,0.95);
      color: #1f1f1f;
      border: 1px solid rgba(255,255,255,0.2);
      padding: 14px;
      border-radius: 30px;
      font-weight: 600;
      font-size: 14.5px;
      cursor: pointer;
      transition: 0.3s;
      margin-top: 14px;
    }

    .google-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(255,255,255,0.2);
    }

    .google-btn img {
      width: 19px;
      height: 19px;
    }

    .divider-row {
      display: flex;
      align-items: center;
      gap: 12px;
      width: 100%;
      margin: 18px 0 0 0;
    }

    .divider-row .line {
      flex: 1;
      height: 1px;
      background: rgba(255,255,255,0.15);
    }

    .divider-row span {
      color: rgba(255,255,255,0.4);
      font-size: 12.5px;
    }

    /* === Modal === */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(3, 7, 20, 0.75);
      backdrop-filter: blur(6px);
      z-index: 4000;
      display: none;
      justify-content: center;
      align-items: center;
      padding: 20px;
      box-sizing: border-box;
    }

    .modal-overlay.active {
      display: flex;
    }

    .modal-box {
      background: rgba(13, 27, 62, 0.95);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 22px;
      padding: 35px 30px;
      width: 100%;
      max-width: 360px;
      box-shadow: 0 25px 60px rgba(0,0,0,0.6);
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .modal-box h3 {
      color: #ffaa00;
      margin: 0 0 8px 0;
      font-size: 1.4em;
      text-align: center;
    }

    .modal-box p.modal-desc {
      color: rgba(255,255,255,0.55);
      font-size: 13.5px;
      margin: 0 0 22px 0;
      text-align: center;
    }

    .modal-close {
      align-self: flex-end;
      background: none;
      border: none;
      color: rgba(255,255,255,0.5);
      font-size: 22px;
      cursor: pointer;
      margin: -10px -8px 0 0;
      line-height: 1;
    }

    .modal-close:hover {
      color: white;
    }

    /* === Toast === */
    #toastContainer {
      position: fixed;
      top: 100px;
      right: 25px;
      z-index: 5000;
      display: flex;
      flex-direction: column;
      gap: 12px;
      max-width: 340px;
    }

    .toast {
      background: rgba(13, 27, 62, 0.92);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.12);
      border-left: 4px solid #ffaa00;
      border-radius: 14px;
      padding: 14px 18px;
      box-shadow: 0 15px 35px rgba(0,0,0,0.5);
      color: white;
      font-size: 14px;
      line-height: 1.4;
      opacity: 0;
      transform: translateX(40px);
      transition: all 0.35s ease;
    }

    .toast.show {
      opacity: 1;
      transform: translateX(0);
    }

    .toast.toast-success {
      border-left-color: #2ecc71;
    }

    .toast.toast-error {
      border-left-color: #e74c3c;
    }

    /* === Footer === */
    footer {
      text-align: center;
      padding: 20px;
      color: #FFD700;
      font-weight: 600;
      margin-top: 40px;
      border-top: 1px solid rgba(255,255,255,0.2);
      background: rgba(255,255,255,0.05);
      backdrop-filter: blur(10px);
    }

    footer:hover {
      background: rgba(255,255,255,0.15);
      color: #fff;
      transition: 0.4s;
    }

    /* === Mobil === */
    @media (max-width: 700px) {
      header {
        height: auto;
        flex-direction: column;
        gap: 10px;
        padding: 15px 20px;
      }

      nav ul {
        flex-direction: column;
        align-items: center;
        width: 100%;
      }

      nav ul li a {
        width: 100%;
        text-align: center;
        padding: 10px 0;
      }

      .header-right {
        width: 100%;
        justify-content: flex-end;
        padding-right: 10px;
      }

      .dropdown-menu {
        right: 10px;
        top: 60px;
        min-width: 180px;
      }

      .content-wrapper {
        padding: 20px 15px;
      }

      .content-wrapper h1 {
        font-size: 1.8em;
      }

      .auth-card {
        padding: 30px 20px;
      }

      #toastContainer {
        top: 10px;
        right: 10px;
        left: 10px;
        max-width: none;
      }
    }
  </style>
</head>

<body>
  <div id="toastContainer"></div>

  <header>
    <a href="index.html" class="logo">
      <img src="https://maqalux.github.io/Picsart_25-10-28_10-01-29-931.png" alt="Maqalux loqosu">
    </a>
    <nav>
      <ul>
        <li><a href="index.html" class="active">Ana səhifə</a></li>
        <li><a href="xeberler.html">Xəbərlər</a></li>
        <li><a href="proqramlar.html">Proqramlar</a></li>
        <li><a href="şahmat.html">Şahmat</a></li>
        <li><a href="eylence.html">Əyləncə</a></li>
        <li><a href="onlinechat.html">Onlayn çat</a></li>
        <li><a href="haqqimizda.html">Haqqımızda</a></li>
        <li><a href="elaqe.html">Əlaqə</a></li>
      </ul>
    </nav>
    <div class="header-right">
      <img id="headerAvatar" class="profile-avatar" src="https://www.w3schools.com/howto/img_avatar.png" alt="Profil" onclick="toggleDropdown(event)">
      <div class="dropdown-menu" id="dropdownMenu">
        <button class="dropdown-item" onclick="changeProfilePicture()">📸 Profil şəklini dəyiş</button>
        <button class="dropdown-item" onclick="openChangePasswordModal()">🔑 Şifrəni dəyiş</button>
        <button class="dropdown-item danger" onclick="deleteAccount()">🗑️ Hesabı sil</button>
        <button class="dropdown-item" onclick="handleLogout()" style="color: #ff6b6b;">🚪 Çıxış</button>
      </div>
    </div>
  </header>

  <main>
    <!-- Auth hissəsi (daxil deyilsə) -->
    <div id="authSection" class="auth-overlay">
      <!-- Login -->
      <div id="loginFormCard" class="auth-card">
        <h2>Maqalux</h2>
        <p class="sub">Daxil olun və saytdan tam faydalanın</p>
        <div class="input-group">
          <input type="email" id="loginEmailInput" class="custom-input" placeholder="E-poçt ünvanınız">
          <div class="password-wrapper">
            <input type="password" id="loginPasswordInput" class="custom-input" placeholder="Şifrəniz">
            <span class="toggle-password" onclick="togglePasswordVisibility('loginPasswordInput', this)">👁️</span>
          </div>
          <button class="login-btn" onclick="handleLogin()">Daxil ol</button>
          <p class="forgot-pass-link" onclick="openForgotPasswordModal()">Şifrəni unutdunuzmu?</p>

          <div class="divider-row"><div class="line"></div><span>VƏ YA</span><div class="line"></div></div>
          <button type="button" class="google-btn" onclick="handleGoogleLogin()">
            <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google">
            Google ilə daxil ol
          </button>

          <p class="switch-text">Hesabınız yoxdur? <span onclick="toggleAuthForms('register')">Qeydiyyatdan keçin</span></p>
        </div>
      </div>

      <!-- Register -->
      <div id="registerFormCard" class="auth-card" style="display: none;">
        <h2>Yeni Qeydiyyat</h2>
        <p class="sub">Hesab yaradın və icmaya qoşulun</p>
        <div class="input-group">
          <input type="text" id="registerNicknameInput" class="custom-input" placeholder="İstifadəçi adı">
          <input type="email" id="registerEmailInput" class="custom-input" placeholder="E-poçt ünvanınız">
          <div class="password-wrapper">
            <input type="password" id="registerPasswordInput" class="custom-input" placeholder="Şifrəniz">
            <span class="toggle-password" onclick="togglePasswordVisibility('registerPasswordInput', this)">👁️</span>
          </div>
          <button class="login-btn" onclick="handleRegister()">Qeydiyyatı Tamamla</button>

          <div class="divider-row"><div class="line"></div><span>VƏ YA</span><div class="line"></div></div>
          <button type="button" class="google-btn" onclick="handleGoogleLogin()">
            <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google">
            Google ilə daxil ol
          </button>

          <p class="switch-text">Artıq hesabınız var? <span onclick="toggleAuthForms('login')">Daxil olun</span></p>
        </div>
      </div>
    </div>

    <!-- Əsas məzmun (daxil olduqda) -->
    <div id="mainContent" style="display: none;">
      <div class="content-wrapper">
        <h1>Ana səhifə</h1>
        <p>Maqalux saytına xoş gəlmisiniz! Burada faydalı məlumatlar, xəbərlər və əyləncəli məzmun tapa bilərsiniz.</p>
        <p style="margin-top: 20px; font-size: 0.95em; color: rgba(255,255,255,0.7);">
          Siz daxil olduğunuz üçün onlayn çatda da aktiv görünürsünüz. İstənilən vaxt <a href="onlinechat.html" style="color: #ffaa00; text-decoration: underline;">çata keçə</a> bilərsiniz.
        </p>
      </div>
    </div>
  </main>

  <!-- Forgot Password Modal -->
  <div class="modal-overlay" id="forgotPasswordModal">
    <div class="modal-box">
      <button class="modal-close" onclick="closeForgotPasswordModal()">✕</button>
      <h3>Şifrəni unutmusunuz?</h3>
      <p class="modal-desc">E-poçt ünvanınızı daxil edin, bərpa linki göndəriləcək.</p>
      <input type="email" id="forgotEmailInput" class="custom-input" placeholder="E-poçt ünvanınız">
      <button class="login-btn" onclick="submitForgotPassword()">Bərpa linki göndər</button>
    </div>
  </div>

  <!-- Change Password Modal -->
  <div class="modal-overlay" id="changePasswordModal">
    <div class="modal-box">
      <button class="modal-close" onclick="closeChangePasswordModal()">✕</button>
      <h3>Şifrəni dəyiş</h3>
      <p class="modal-desc">Köhnə və yeni şifrəni daxil edin.</p>
      <div class="input-group">
        <div class="password-wrapper">
          <input type="password" id="oldPassInput" class="custom-input" placeholder="Köhnə şifrə">
          <span class="toggle-password" onclick="togglePasswordVisibility('oldPassInput', this)">👁️</span>
        </div>
        <div class="password-wrapper">
          <input type="password" id="newPassInput" class="custom-input" placeholder="Yeni şifrə">
          <span class="toggle-password" onclick="togglePasswordVisibility('newPassInput', this)">👁️</span>
        </div>
        <button class="login-btn" onclick="submitChangePassword()">Şifrəni yenilə</button>
      </div>
    </div>
  </div>

  <!-- Delete Account Modal (təsdiq) -->
  <div class="modal-overlay" id="deleteAccountModal">
    <div class="modal-box">
      <button class="modal-close" onclick="closeDeleteAccountModal()">✕</button>
      <h3>Hesabı sil</h3>
      <p class="modal-desc">Bu əməliyyat geri qaytarıla bilməz. Davam etmək üçün şifrənizi daxil edin.</p>
      <div class="input-group">
        <div class="password-wrapper">
          <input type="password" id="deletePassInput" class="custom-input" placeholder="Şifrəniz">
          <span class="toggle-password" onclick="togglePasswordVisibility('deletePassInput', this)">👁️</span>
        </div>
        <button class="login-btn" style="background: linear-gradient(90deg, #e74c3c, #c0392b); color:white;" onclick="submitDeleteAccount()">Hesabımı həmişəlik sil</button>
      </div>
    </div>
  </div>

  <footer>
    &copy; 2025 Maqalux - Bütün hüquqlar qorunur.
  </footer>

